{
    "compilerOptions": {
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "react-jsx",
        "incremental": true,
        "strictPropertyInitialization": true,
        "paths": {
            "@store/*": ["./src/store/*"],
            "@store": ["./src/store"],
            "@components/*": [
                "./src/ui/components/protons/*",
                "./src/ui/components/atoms/*",
                "./src/ui/components/molecules/*",
                "./src/ui/components/organisms/*",
                "./src/ui/components/templates/*"
            ],
            "@queries/*": ["./src/ui/operations/queries/*"],
            "@mutations": ["./src/ui/operations/mutations"],
            "@mutations/*": ["./src/ui/operations/mutations/*"],
            "@ui/*": ["./src/ui/*"],
            "@helpers/*": ["./src/helpers/*"],
            "@scenes/*": ["./src/scenes/*"],
            "@entities/*": ["./src/entities/*"],
            "@services/*": ["./src/services/*"],
            "@config/*": ["./src/config/*"],
            "@types/*": ["./src/types/*"],
            "@/*": ["./src/*"]
        },
        "target": "ES2017"
    },
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": [
        "node_modules",
        "assets/**/*.tsx",
        "assets/**/*.tmx",
        "assets/**/*.tmj",
        "public/**/*.tsx",
        "public/**/*.tmx",
        "public/**/*.tmj",
        "dist/**/*.tsx",
        "dist/**/*.tmx",
        "dist/**/*.tmj",
        "server/**/*"
    ]
}
