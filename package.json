{
    "name": "phasercraft",
    "version": "2.0.0",
    "private": true,
    "engines": {
        "node": ">=22"
    },
    "homepage": "https://chriskinch.github.io/phasercraft/dist",
    "description": "A Phaser 3 + React/Redux browser RPG, bundled with Vite.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/chriskinch/phasercraft.git"
    },
    "keywords": [
        "phaser",
        "phaser3",
        "vite",
        "react",
        "typescript"
    ],
    "scripts": {
        "dev": "node log.js dev & vite",
        "build": "node log.js build & vite build",
        "dev-nolog": "vite",
        "lint": "eslint .",
        "build-nolog": "vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "test:e2e": "playwright test --project=smoke",
        "test:e2e:full": "playwright test",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "simple-git-hooks",
        "gateway": "cd server && yarn start"
    },
    "dependencies": {
        "@apollo/client": "^3.13.8",
        "@reduxjs/toolkit": "^2.8.2",
        "@vercel/kv": "^3.0.0",
        "fantasy-content-generator": "^4.9.1",
        "lodash": "^4.18.1",
        "number-to-words": "^1.2.4",
        "phaser": "^3.90.0",
        "polished": "^4.3.1",
        "react": "19.0.0",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dnd-touch-backend": "^16.0.1",
        "react-dom": "19.0.0",
        "react-redux": "^9.2.0",
        "react-tooltip": "^5.29.1",
        "rxjs": "^7.8.2",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/lodash": "^4.17.20",
        "@types/node": "^22.19.21",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@typescript-eslint/eslint-plugin": "^8.61.0",
        "@typescript-eslint/parser": "^8.61.0",
        "@vercel/node": "^5.8.17",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/coverage-v8": "^4.1.6",
        "@vitest/ui": "^4.1.6",
        "eslint": "^9.31.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^5.2.0",
        "gh-pages": "^6.3.0",
        "jsdom": "^29.1.1",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "react-dnd-test-backend": "^16.0.1",
        "serve": "^14.2.6",
        "simple-git-hooks": "^2.13.1",
        "typescript": "^5",
        "vite": "^8.0.16",
        "vitest": "^4.1.6"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,md,css,yml,yaml}": [
            "prettier --write"
        ]
    }
}
