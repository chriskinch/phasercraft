{
    "name": "phasercraft",
    "version": "2.0.0",
    "private": true,
    "homepage": "https://chriskinch.github.io/phasercraft/dist",
    "description": "A Phaser 3 Next.js project template that demonstrates Next.js with React communication and uses Vite for bundling.",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/chriskinch/phasercraft.git"
    },
    "keywords": [
        "phaser",
        "phaser3",
        "next",
        "nextjs",
        "vite",
        "typescript"
    ],
    "scripts": {
        "dev": "node log.js dev & next dev -p 8080",
        "build": "node log.js build & next build",
        "dev-nolog": "next dev -p 8080",
        "lint": "next lint",
        "build-nolog": "next build",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "simple-git-hooks",
        "gateway": "cd server && yarn start",
        "service:armory": "cd services/armory && sls offline start"
    },
    "dependencies": {
        "@apollo/client": "^3.13.8",
        "@reduxjs/toolkit": "^2.8.2",
        "eslint-config-next": "^15.4.2",
        "lodash": "^4.18.1",
        "next": "15.5.18",
        "number-to-words": "^1.2.4",
        "phaser": "^3.90.0",
        "polished": "^4.3.1",
        "react": "19.0.0",
        "react-dnd": "^16.0.1",
        "react-dnd-html5-backend": "^16.0.1",
        "react-dnd-touch-backend": "^16.0.1",
        "react-dom": "19.0.0",
        "react-redux": "^9.2.0",
        "react-tooltip": "^5.29.1",
        "rxjs": "^7.8.2",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/lodash": "^4.17.20",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitest/ui": "^4.1.6",
        "eslint": "^9.31.0",
        "eslint-config-prettier": "^10.1.8",
        "gh-pages": "^6.3.0",
        "jsdom": "^29.1.1",
        "lint-staged": "^16.4.0",
        "postcss": "^8.5.10",
        "prettier": "^3.8.3",
        "simple-git-hooks": "^2.13.1",
        "typescript": "^5",
        "vitest": "^4.1.6"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{json,md,css,yml,yaml}": [
            "prettier --write"
        ]
    }
}
